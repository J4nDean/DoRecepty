// Schema dopasowany do istniejących tabel Postgres (Spring Boot JPA).
// Wygenerowany ręcznie — możesz odświeżyć przez `npx prisma db pull` po podpięciu DATABASE_URL.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           BigInt    @id @default(autoincrement())
  firstName    String?   @map("first_name")
  lastName     String?   @map("last_name")
  email        String    @unique
  passwordHash String    @map("password_hash")
  pesel        String?   @unique
  role         String?
  createdAt    DateTime? @default(now()) @map("created_at") @db.Timestamptz()

  prescriptions Prescription[]

  @@map("app_user")
}

model Medication {
  id                   BigInt  @id @default(autoincrement())
  gtin                 String?
  name                 String
  commonName           String? @map("common_name")
  strength             String?
  pharmaceuticalForm   String? @map("pharmaceutical_form")
  packageSize          String? @map("package_size")
  atcCode              String? @map("atc_code")
  prescriptionCategory String? @map("prescription_category")

  items PrescriptionItem[]

  @@map("medication")
}

model Prescription {
  id             BigInt    @id @default(autoincrement())
  packageKey     String?   @unique @map("package_key")
  accessCode     String?   @map("access_code")
  issueDate      DateTime? @map("issue_date") @db.Date
  expirationDate DateTime? @map("expiration_date") @db.Date
  patientId      BigInt?   @map("patient_id")
  doctorNpwz     String?   @map("doctor_npwz")
  clinicRegon    String?   @map("clinic_regon")
  status         String?

  patient User?              @relation(fields: [patientId], references: [id])
  items   PrescriptionItem[]

  @@map("prescription")
}

model PrescriptionItem {
  id                  BigInt    @id @default(autoincrement())
  prescriptionId      BigInt    @map("prescription_id")
  prescriptionOid     String?   @unique @map("prescription_oid")
  oidPrefix           String?   @map("oid_prefix")
  positionInPackage   Int?      @map("position_in_package")
  medicationId        BigInt    @map("medication_id")
  quantity            Int?
  dosageInstructions  String?   @map("dosage_instructions")
  realizationDateFrom DateTime? @map("realization_date_from") @db.Date
  refundLevel         String?   @map("refund_level")
  status              String?

  prescription Prescription @relation(fields: [prescriptionId], references: [id])
  medication   Medication   @relation(fields: [medicationId], references: [id])

  @@map("prescription_item")
}
